# ============================================================
# MuPGA Web — Variables de entorno
# Copiar a .env y completar con los valores reales.
# NUNCA commitear el .env con credenciales reales.
# ============================================================

# ── Base de datos SQL Server ──────────────────────────────────
# Instancia nombrada: incluir el nombre en DB_HOST (ej. localhost\SQLEXPRESS01).
# DB_PORT: dejar vacío para que SQL Server Browser resuelva automáticamente.
# Si Browser no corre y querés puerto fijo: SQL Server Config Manager
# → Protocols for SQLEXPRESS01 → TCP/IP → IP Addresses → IPAll → TCP Port.
DB_HOST=localhost\SQLEXPRESS01
DB_PORT=
DB_NAME=MuOnline
DB_USER=sa
DB_PASS=

# true  → usa [dbo].[fn_md5](password, username) — mismo método que el GameServer
# false → contraseña en texto plano (no recomendado)
DB_USE_MD5=true

# ── Autenticación ─────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT.
# MIGRACIÓN: Generar en el VPS con: php -r "echo bin2hex(random_bytes(32));"
# Mínimo 32 caracteres. Cambiarla invalida todos los tokens activos.
APP_SECRET=

# ── CORS (cross-origin para Cloudflare Pages → VPS) ──────────
# MIGRACIÓN: Agregar los dominios de Cloudflare Pages separados por coma.
# Ejemplo: https://mupga.pages.dev,https://mupga.com
# En local no hace falta — localhost está permitido por defecto.
CORS_ALLOWED_ORIGINS=

# ── Donaciones / Tienda WCoin ─────────────────────────────────
# URL base de la API externa de pagos (sin barra final).
# Usada por el proxy PHP (api/donate/order.php) para reenviar órdenes.
# Ejemplo desarrollo: http://localhost:5000
# Ejemplo producción: https://pagos-api.mupga.com.ar
PAYMENTS_API_URL=http://localhost:5000

# URL legacy — se puede dejar vacía al activar la nueva integración.
DONATION_URL=

# ── Rankings ─────────────────────────────────────────────────
RANKINGS_LIMIT=25
# Cuentas de admin a ocultar de todos los rankings (separadas por coma).
# Se excluyen por AccountID (memb___id), no por nombre de personaje.
RANKINGS_EXCLUDED_ACCOUNTS=

# ── Cloudflare Turnstile (captcha en registro) ────────────────
# Obtener claves en: https://dash.cloudflare.com → Turnstile
# Dejar vacío para deshabilitar el captcha (dev local).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Reset de personaje ────────────────────────────────────────
RESET_LEVEL_REQUIRED=400
RESET_COST_ZEN=10000000
RESET_STATS=true
RESET_BONUS_POINTS=350
RESET_MAX_RESETS=300

# ── Prode MuPGA ──────────────────────────────────────────────
# Conexión con prode_user (mismo SQL Server, misma DB que DB_HOST/DB_NAME).
# Crear el usuario con database/prode_setup.sql antes de activar el módulo.
PRODE_DB_HOST=localhost\SQLEXPRESS01
PRODE_DB_PORT=
PRODE_DB_NAME=MuOnline
PRODE_DB_USER=prode_user
PRODE_DB_PASS=

# Token para los endpoints de administración del prode (/api/prode/admin_*.php).
# Enviarlo en el header: X-Admin-Token: <valor>
# Generar con: php -r "echo bin2hex(random_bytes(24));"
ADMIN_TOKEN=

# ── Entorno ───────────────────────────────────────────────────
# development → muestra errores detallados
# production  → errores genéricos
APP_ENV=development
APP_BASE_URL=http://localhost/
