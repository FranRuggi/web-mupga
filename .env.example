# ============================================================
# MuPGA Web — Variables de entorno
# Copiar a .env y completar con los valores reales.
# NUNCA commitear el .env con credenciales reales.
# ============================================================

# Conexión SQL Server
# Instancia nombrada: incluir el nombre en DB_HOST (ej. localhost\SQLEXPRESS01).
# DB_PORT: dejar vacío para que SQL Server Browser resuelva el puerto automáticamente.
# Si Browser no corre y querés puerto fijo: SQL Server Config Manager
# → Protocols for SQLEXPRESS01 → TCP/IP → IP Addresses → IPAll → TCP Port.
DB_HOST=localhost\SQLEXPRESS01
DB_PORT=
DB_NAME=MuOnline
DB_USER=sa
DB_PASS=

# true  → usa [dbo].[fn_md5](password, username) en SQL Server (mismo método que el GameServer)
# false → contraseña en texto plano
DB_USE_MD5=true

# Límite de resultados por defecto en rankings
RANKINGS_LIMIT=25

# Entorno: development | production
APP_ENV=development
APP_BASE_URL=http://localhost/mupga/
